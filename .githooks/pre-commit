#!/bin/sh
#
# ThreatCrush Pre-commit Hook
# Runs build checks before allowing commits.
#

set -e

echo "🔍 Running pre-commit checks..."
echo ""

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

FAILED=0

run_check() {
    local name="$1"
    local cmd="$2"

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📋 $name"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if eval "$cmd"; then
        echo "${GREEN}✅ $name passed${NC}"
        echo ""
    else
        echo "${RED}❌ $name failed${NC}"
        echo ""
        FAILED=1
    fi
}

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo "No files staged for commit."
    exit 0
fi

# Build CLI
run_check "Build CLI" "pnpm --filter @profullstack/threatcrush build"

# Build landing page
run_check "Build Landing Page" "pnpm --filter threatcrush build"

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 1 ]; then
    echo "${RED}❌ Pre-commit checks failed!${NC}"
    echo ""
    echo "Fix the issues above before committing."
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
else
    echo "${GREEN}✅ All pre-commit checks passed!${NC}"
    echo ""
fi
